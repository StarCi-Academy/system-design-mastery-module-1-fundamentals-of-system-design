  "devDependencies": {
    "@nestjs/cli": "^10.0.0",
    "@nestjs/schematics": "^10.0.0",
    "@types/node": "^20.3.1",
    "tsc-alias": "^1.8.8",
    "typescript": "^5.1.3"
  }
}
